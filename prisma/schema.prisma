generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GuildConfig {
  guildId                 String      @id @map("guild_id")
  logChannelId            String?     @map("log_channel_id")
  welcomeChannelId        String?     @map("welcome_channel_id")
  suggestionChannelId     String?     @map("suggestion_channel_id")
  ticketCategoryId        String?     @map("ticket_category_id")
  createVcChannelId       String?     @map("create_vc_channel_id")
  anonymousSuggestion     Boolean     @default(true) @map("anonymous_suggestion")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")
  rolePanels              RolePanel[]
  strikeUsers             StrikeUser[]
  strikeHistories         StrikeHistory[]
  strikeRules             StrikeRule[]
  tempVoiceChannels       TempVC[]
  tickets                 Ticket[]

  @@map("GuildConfig")
}

model StrikeUser {
  guildId       String       @map("guild_id")
  userId        String       @map("user_id")
  strikeCount   Int          @default(0) @map("strike_count")
  lastStrikeAt  DateTime?    @map("last_strike_at")
  guild         GuildConfig  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@id([guildId, userId])
  @@map("StrikeUser")
}

model StrikeHistory {
  id           Int          @id @default(autoincrement())
  guildId      String       @map("guild_id")
  userId       String       @map("user_id")
  moderatorId  String?      @map("moderator_id")
  amount       Int
  reason       String?
  createdAt    DateTime     @default(now()) @map("created_at")
  guild        GuildConfig  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId, userId, createdAt])
  @@map("StrikeHistory")
}

model StrikeRule {
  guildId   String        @map("guild_id")
  strike    Int
  action    StrikeAction
  duration  Int?
  roleId    String?       @map("role_id")
  guild     GuildConfig   @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@id([guildId, strike])
  @@map("StrikeRule")
}

model TempVC {
  channelId  String       @id @map("channel_id")
  guildId    String       @map("guild_id")
  ownerId    String       @map("owner_id")
  createdAt  DateTime     @default(now()) @map("created_at")
  guild      GuildConfig  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId, ownerId])
  @@map("TempVC")
}

model Ticket {
  ticketId   Int           @id @default(autoincrement()) @map("ticket_id")
  guildId    String        @map("guild_id")
  userId     String        @map("user_id")
  channelId  String        @unique @map("channel_id")
  status     TicketStatus  @default(OPEN)
  createdAt  DateTime      @default(now()) @map("created_at")
  guild      GuildConfig   @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId, userId, status])
  @@map("Ticket")
}

model RolePanel {
  id           String             @id @default(cuid())
  guildId      String             @map("guild_id")
  channelId    String?            @map("channel_id")
  messageId    String?            @unique @map("message_id")
  title        String
  description  String?
  createdById  String             @map("created_by_id")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  guild        GuildConfig        @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  options      RolePanelOption[]

  @@index([guildId])
  @@map("RolePanel")
}

model RolePanelOption {
  id         String     @id @default(cuid())
  panelId    String     @map("panel_id")
  roleId     String     @map("role_id")
  label      String
  emoji      String?
  createdAt  DateTime   @default(now()) @map("created_at")
  panel      RolePanel  @relation(fields: [panelId], references: [id], onDelete: Cascade)

  @@unique([panelId, roleId])
  @@map("RolePanelOption")
}

enum StrikeAction {
  WARNING
  TIMEOUT
  KICK
  BAN
}

enum TicketStatus {
  OPEN
  CLOSED
}
